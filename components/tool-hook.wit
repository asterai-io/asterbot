/// Tool hook interface for intercepting tool calls.
/// Components implementing this interface are called
/// before and after every tool invocation, enabling
/// security gating, tracing, rate limiting, etc.
///
/// Hooks are registered via the ASTERBOT_TOOL_HOOKS
/// env var (comma-separated component names) and
/// called in order. Any hook returning deny or confirm
/// short-circuits the chain.
interface tool-hook {
  /// The result of a before-call hook.
  enum hook-result {
    /// Allow the tool call to proceed.
    allow,
    /// Deny the tool call.
    deny,
    /// Pause execution and ask the user to confirm.
    confirm,
  }

  /// Response from a before-call hook.
  record hook-response {
    /// Whether to allow, deny, or confirm.
    result: hook-result,
    /// Optional message shown to the user (e.g.
    /// denial reason or confirmation prompt).
    message: option<string>,
  }

  /// Called before a tool function is executed.
  /// Receives the target component, function name
  /// (e.g. "email/send"), and the arguments as JSON.
  before-call: func(
    component: string,
    function-name: string,
    args: string,
  ) -> hook-response;

  /// Called after a tool function has executed.
  /// Receives the same identifiers plus the result.
  after-call: func(
    component: string,
    function-name: string,
    args: string,
    result: string,
  );
}
